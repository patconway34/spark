# Required: Groq API key for Whisper speech-to-text
# Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional: Whisper model (default: whisper-large-v3-turbo)
# GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# Optional: Terminal base URL (default: http://localhost)
# Set this if your ttyd terminals are behind a reverse proxy
# SPARK_TERMINAL_URL=https://terminal.example.com

# Optional: Working directory for tmux sessions (default: $HOME)
# SPARK_PROJECT_DIR=/home/user/projects

# Optional: Secret key for session cookies (auto-generated if not set)
# SPARK_SECRET_KEY=some-random-string
